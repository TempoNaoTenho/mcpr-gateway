# HTTP bind address. Default 127.0.0.1; use 0.0.0.0 for Docker or LAN exposure.
HOST=127.0.0.1
# MCP clients (e.g. Cursor): use http://127.0.0.1:<gateway-port>/mcp/<namespace> in settings.
# With HOST=127.0.0.1 the server listens on IPv4 loopback only; http://localhost:... may resolve to ::1 and fail with "fetch failed".
# Alternative: set GATEWAY_DUAL_STACK=1 to bind :: (IPv4-mapped + IPv6; may accept all interfaces—firewall on untrusted networks).
# GATEWAY_DUAL_STACK=1
PORT=3000
LOG_LEVEL=info

# Directory containing bootstrap.json (not the file path). Docker images use /config.
CONFIG_PATH=./config

# --- Recommended security (uncomment and set in your real .env; do not commit secrets) ---
#
# When set to any non-empty value, /admin/* requires a session from POST /admin/auth/login
# (GATEWAY_ADMIN_USER / GATEWAY_ADMIN_PASSWORD). The value is not used as a password. See docs/deployment.md.
# ADMIN_TOKEN=

# Admin WebUI username (default mcpgateway). Must match the login form when ADMIN_TOKEN is set.
# GATEWAY_ADMIN_USER=mcpgateway

# Admin WebUI password. When unset (with ADMIN_TOKEN set), you can sign in with username only.
# When set, login requires this password for GATEWAY_ADMIN_USER.
# If ADMIN_TOKEN is not set, the admin panel is unprotected (see docs/deployment.md).
# GATEWAY_ADMIN_PASSWORD=

# Base64-encoded 32-byte key for UI-managed downstream bearer/OAuth secrets at rest (SQLite only).
# Must decode from base64 to exactly 32 bytes.
# Generate: openssl rand -base64 32
# DOWNSTREAM_AUTH_ENCRYPTION_KEY=

# --- Persistence ---
# Default is SQLite (./data/gateway.db, or DATABASE_PATH below). The code only treats the
# literal value "memory" specially; anything else (including unset) uses SQLite.
# Optional: no on-disk DB — sessions lost on restart; admin saves go to CONFIG_PATH/bootstrap.json;
# no config versions, no SQLite audit table, no persisted managed downstream secrets.
# SESSION_BACKEND=memory

# SQLite file path (ignored when SESSION_BACKEND=memory).
# Under Vitest, a per-worker file under the system temp directory is used unless DATABASE_PATH is set.
# DATABASE_PATH=./data/gateway.db

# Set to production to disable mounting admin routes unless debug or ADMIN_TOKEN applies. See docs/deployment.md.
# NODE_ENV=production

# Default retention for DELETE /admin/audit/prune when ?days is omitted.
# AUDIT_RETENTION_DAYS=90

# Optional: only if gateway.json uses ${VAR_NAME} placeholders (missing vars → startup fails).
# Client access tokens are usually created in the admin UI (Access Control); no dedicated .env name is required.

# Optional: override built UI location (else ui/dist, then ui/build under cwd).
# UI_STATIC_DIR=./ui/build

# Optional: Custom MCP Servers Env Variables
# YOUR_VARIABLE_NAME=your-value
# YOUR_VARIABLE_NAME2=your-value2